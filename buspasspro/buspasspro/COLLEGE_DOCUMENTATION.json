{
  "project": "BusPassPro",
  "title": "BusPassPro Project Documentation",
  "purpose": "College submission documentation covering the use case diagram, class diagram methods, and data dictionary.",
  "sections": {
    "use_case_diagram": {
      "actors": [
        "Student",
        "Admin",
        "Authorized Staff",
        "System"
      ],
      "use_cases": {
        "student": [
          "Register / Login",
          "View Routes",
          "Apply for Bus Pass",
          "Upload Documents",
          "Make Payment",
          "Track Application Status",
          "Download Digital Pass",
          "View QR Code",
          "Book Taxi",
          "View Nearby Taxis"
        ],
        "admin": [
          "Review Applications",
          "Approve / Reject Pass",
          "Manage Routes",
          "Manage Buses",
          "Send Notifications",
          "Generate Reports"
        ],
        "authorized_staff": [
          "Scan QR Pass",
          "Validate Pass",
          "Record Boarding",
          "Track Bus / Taxi Location"
        ],
        "system": [
          "Process Payment",
          "Issue Pass and QR",
          "Dispatch Notifications",
          "Store Live Tracking Data"
        ]
      },
      "summary": [
        "Student workflows focus on registration, pass application, payment, and pass usage.",
        "Admin workflows focus on review, approval, route management, bus management, and reporting.",
        "Authorized staff workflows focus on QR validation and boarding verification.",
        "System workflows cover payment processing, QR generation, notifications, and tracking updates."
      ]
    },
